<odoo>
  <data>
    <record id="view_camarero_list" model="ir.ui.view">
      <field name="name">camarero.list</field>
      <field name="model">sg_restaurante.camarero</field>
      <field name="arch" type="xml">
        <list>
          <field name="user_id"/>
          <field name="pedidos_id"/>
          <field name="total_pedidos"/>
        </list>
      </field>
    </record>
    <record id="view_camarero_form" model="ir.ui.view">
      <field name="name">camarero.form</field>
      <field name="model">sg_restaurante.camarero</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="user_id" required="1"/>
            <field name="pedidos_id"/>
            <field name="total_pedidos"/>
          </group>
        </form>
      </field>
    </record>
    <record id="view_camarero_graph" model="ir.ui.view">
      <field name="name">camarero.graph</field>
      <field name="model">sg_restaurante.camarero</field>
      <field name="arch" type="xml">
        <graph string="Graph view" type="bar">
          <field name="user_id" type="row"/>
          <field name="total_pedidos" type="measure"/>
        </graph>
      </field>
    </record>
    <record id="view_pedido_list" model="ir.ui.view">
      <field name="name">pedido.list</field>
      <field name="model">sg_restaurante.pedido</field>
      <field name="arch" type="xml">
        <list>
          <field name="mesa_id"/>
          <field name="cliente_id"/>
          <field name="platos_id"/>
          <field name="estado"/>
          <field name="tiempo_pedido"/>
          <field name="camarero_id"/>
        </list>
      </field>
    </record>
    <record id="view_pedido_form" model="ir.ui.view">
      <field name="name">pedido.form</field>
      <field name="model">sg_restaurante.pedido</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="mesa_id" required="1"/>
            <field name="cliente_id" required="1"/>
            <field name="platos_id"/>
            <field name="estado"/>
            <field name="tiempo_pedido"/>
            <field name="camarero_id" required="1"/>
          </group>
        </form>
      </field>
    </record>
    <record id="view_pedido_calendar" model="ir.ui.view">
      <field name="name">pedido.calendar</field>
      <field name="model">sg_restaurante.pedido</field>
      <field name="arch" type="xml">
        <calendar string="Calendar view" date_start="tiempo_pedido" color="mesa_id">
          <field name="mesa_id"/>
        </calendar>
      </field>
    </record>
    <record id="view_mesa_list" model="ir.ui.view">
      <field name="name">mesa.list</field>
      <field name="model">sg_restaurante.mesa</field>
      <field name="arch" type="xml">
        <list>
          <field name="numero"/>
          <field name="descripcion"/>
          <field name="capacidad"/>
          <field name="estado"/>
          <field name="ubicacion"/>
        </list>
      </field>
    </record>
    <record id="view_mesa_form" model="ir.ui.view">
      <field name="name">mesa.form</field>
      <field name="model">sg_restaurante.mesa</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="numero" required="1"/>
            <field name="descripcion"/>
            <field name="capacidad" required="1"/>
            <field name="estado" required="1"/>
            <field name="ubicacion"/>
          </group>
        </form>
      </field>
    </record>
    <record id="view_mesa_kanban" model="ir.ui.view">
      <field name="name">mesa.kanban</field>
      <field name="model">sg_restaurante.mesa</field>
      <field name="arch" type="xml">
        <kanban default_group_by="estado">
          <templates>
            <t t-name="card">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <strong class="o_kanban_record_title">
                    <field name="numero"/>
                  </strong>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>
    <record id="view_plato_list" model="ir.ui.view">
      <field name="name">plato.list</field>
      <field name="model">sg_restaurante.plato</field>
      <field name="arch" type="xml">
        <list>
          <field name="nombre"/>
          <field name="categoria"/>
          <field name="precio"/>
          <field name="descripcion"/>
          <field name="proveedor_id"/>
        </list>
      </field>
    </record>
    <record id="view_plato_form" model="ir.ui.view">
      <field name="name">plato.form</field>
      <field name="model">sg_restaurante.plato</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="nombre" required="1"/>
            <field name="categoria"/>
            <field name="precio" required="1"/>
            <field name="descripcion"/>
            <field name="proveedor_id"/>
          </group>
        </form>
      </field>
    </record>
    <record id="view_plato_graph" model="ir.ui.view">
      <field name="name">plato.graph</field>
      <field name="model">sg_restaurante.plato</field>
      <field name="arch" type="xml">
        <graph string="Graph view" type="bar">
          <field name="categoria" type="row"/>
          <field name="precio" type="measure"/>
        </graph>
      </field>
    </record>
    <record id="action_camarero" model="ir.actions.act_window">
      <field name="name">Camarero</field>
      <field name="res_model">sg_restaurante.camarero</field>
      <field name="view_mode">list,form,graph</field>
    </record>
    <record id="action_pedido" model="ir.actions.act_window">
      <field name="name">Pedido</field>
      <field name="res_model">sg_restaurante.pedido</field>
      <field name="view_mode">list,form,calendar</field>
    </record>
    <record id="action_mesa" model="ir.actions.act_window">
      <field name="name">Mesa</field>
      <field name="res_model">sg_restaurante.mesa</field>
      <field name="view_mode">list,form,kanban</field>
    </record>
    <record id="action_plato" model="ir.actions.act_window">
      <field name="name">Plato</field>
      <field name="res_model">sg_restaurante.plato</field>
      <field name="view_mode">list,form,graph</field>
    </record>
    <menuitem id="menu_root_sg_restaurante" name="SG Restaurante" sequence="1"/>
    <menuitem id="menu_camarero" name="Camarero" action="action_camarero" parent="menu_root_sg_restaurante"/>
    <menuitem id="menu_pedido" name="Pedido" action="action_pedido" parent="menu_root_sg_restaurante"/>
    <menuitem id="menu_mesa" name="Mesa" action="action_mesa" parent="menu_root_sg_restaurante"/>
    <menuitem id="menu_plato" name="Plato" action="action_plato" parent="menu_root_sg_restaurante"/>
  </data>
</odoo>
