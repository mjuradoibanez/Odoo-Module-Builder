<odoo>
  <data>
    <menuitem id="menu_root_academia" name="Academia" sequence="1"/>
    <record id="view_alumno_list" model="ir.ui.view">
      <field name="name">alumno.list</field>
      <field name="model">academia.alumno</field>
      <field name="arch" type="xml">
        <list>
          <field name="nombre"/>
          <field name="edad"/>
        </list>
      </field>
    </record>
    <record id="view_alumno_form" model="ir.ui.view">
      <field name="name">alumno.form</field>
      <field name="model">academia.alumno</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="nombre"/>
            <field name="edad"/>
          </group>
        </form>
      </field>
    </record>
    <record id="action_alumno" model="ir.actions.act_window">
      <field name="name">Alumno</field>
      <field name="res_model">academia.alumno</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_alumno" name="Alumno" action="action_alumno" parent="menu_root_academia"/>
    <record id="view_curso_list" model="ir.ui.view">
      <field name="name">curso.list</field>
      <field name="model">academia.curso</field>
      <field name="arch" type="xml">
        <list>
          <field name="titulo"/>
          <field name="descripcion"/>
        </list>
      </field>
    </record>
    <record id="view_curso_form" model="ir.ui.view">
      <field name="name">curso.form</field>
      <field name="model">academia.curso</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="titulo"/>
            <field name="descripcion"/>
          </group>
        </form>
      </field>
    </record>
    <record id="action_curso" model="ir.actions.act_window">
      <field name="name">Curso</field>
      <field name="res_model">academia.curso</field>
      <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_curso" name="Curso" action="action_curso" parent="menu_root_academia"/>
  </data>
</odoo>
