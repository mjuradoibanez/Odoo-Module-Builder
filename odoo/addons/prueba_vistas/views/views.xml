<odoo>
  <data>
    <menuitem id="menu_root_prueba_vistas" name="prueba vistas" sequence="1"/>
    <record id="view_vistas_personal_list" model="ir.ui.view">
      <field name="name">vistas_personal.list</field>
      <field name="model">prueba_vistas.vistas_personal</field>
      <field name="arch" type="xml">
        <list>
          <field name="nombre"/>
          <field name="edad"/>
          <field name="activo"/>
        </list>
      </field>
    </record>
    <record id="view_vistas_personal_form" model="ir.ui.view">
      <field name="name">vistas_personal.form</field>
      <field name="model">prueba_vistas.vistas_personal</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="nombre" required="1"/>
            <field name="edad"/>
            <field name="activo"/>
          </group>
        </form>
      </field>
    </record>
    <record id="view_vistas_personal_search" model="ir.ui.view">
      <field name="name">vistas_personal.search</field>
      <field name="model">prueba_vistas.vistas_personal</field>
      <field name="arch" type="xml">
        <search>
          <field name="nombre"/>
          <field name="edad"/>
        </search>
      </field>
    </record>
    <record id="view_vistas_personal_kanban" model="ir.ui.view">
      <field name="name">vistas_personal.kanban</field>
      <field name="model">prueba_vistas.vistas_personal</field>
      <field name="arch" type="xml">
        <kanban default_group_by="edad">
          <templates>
            <t t-name="card">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <strong class="o_kanban_record_title">
                    <field name="nombre"/>
                  </strong>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>
    <record id="view_vistas_personal_graph" model="ir.ui.view">
      <field name="name">vistas_personal.graph</field>
      <field name="model">prueba_vistas.vistas_personal</field>
      <field name="arch" type="xml">
        <graph string="Graph view" type="bar">
          <field name="activo" type="row"/>
          <field name="edad" type="measure"/>
        </graph>
      </field>
    </record>
    <record id="action_vistas_personal" model="ir.actions.act_window">
      <field name="name">vistas personal</field>
      <field name="res_model">prueba_vistas.vistas_personal</field>
      <field name="view_mode">list,form,kanban,graph</field>
    </record>
    <menuitem id="menu_vistas_personal" name="vistas personal" action="action_vistas_personal" parent="menu_root_prueba_vistas"/>
  </data>
</odoo>
